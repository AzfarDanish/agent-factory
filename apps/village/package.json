{
  "name": "village",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "rm -rf .next",
    "dev": "rm -rf .next && next dev",
    "dev:all": "concurrently -n bridge,next -c yellow,cyan \"cd ../../ && python3 -m src.entrypoints.village_bridge\" \"rm -rf .next && next dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.4"
}
