{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MessageEnvelope",
  "description": "Outer wrapper for every message on every queue",
  "type": "object",
  "required": ["id", "type", "workflow", "version", "timestamp", "trace_id", "payload"],
  "properties": {
    "id": { "type": "string", "format": "uuid", "description": "Unique message ID" },
    "type": {
      "type": "string",
      "description": "Message type — validated against the workflow definition"
    },
    "workflow": {
      "type": "string",
      "description": "Workflow name this message belongs to (e.g. 'coloring', 'research')",
      "default": "coloring"
    },
    "version": { "type": "integer", "minimum": 1, "description": "Schema version" },
    "timestamp": { "type": "string", "format": "date-time", "description": "ISO-8601 timestamp" },
    "trace_id": { "type": "string", "format": "uuid", "description": "Correlation ID across the pipeline" },
    "payload": { "type": "object", "description": "Workflow-specific payload" },
    "metadata": {
      "type": "object",
      "properties": {
        "retry_count": { "type": "integer", "minimum": 0, "default": 0 },
        "source": { "type": "string", "description": "Source agent or module that created the message" }
      }
    }
  }
}
