{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocOutline",
  "description": "Structured document outline generated by the DocOutlineWorker",
  "type": "object",
  "required": ["request_id", "topic", "title", "sections"],
  "properties": {
    "request_id": {
      "type": "string",
      "description": "Correlation ID"
    },
    "topic": {
      "type": "string",
      "description": "Original documentation topic"
    },
    "title": {
      "type": "string",
      "description": "Document title"
    },
    "document_type": {
      "type": "string",
      "description": "Type of document"
    },
    "format": {
      "type": "string",
      "description": "Output format"
    },
    "tone": {
      "type": "string",
      "description": "Writing tone"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heading", "description", "key_points"],
        "properties": {
          "heading": { "type": "string", "description": "Section heading" },
          "description": { "type": "string", "description": "What this section should cover" },
          "key_points": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Key points to include in this section"
          },
          "code_examples": {
            "type": "boolean",
            "default": false,
            "description": "Whether this section should include code examples"
          }
        }
      }
    },
    "target_audience": {
      "type": "string",
      "description": "Target audience description"
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Prerequisites the reader should have"
    }
  }
}
