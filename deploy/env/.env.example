# Coloring Page Factory — Environment Variables
# Copy to .env and fill in values.

# Queue backend (file | redis)
FACTORY_QUEUE_BACKEND=file

# DeepSeek API
FACTORY_DEEPSEEK_API_KEY=
FACTORY_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI (GPT Image 1)
FACTORY_OPENAI_API_KEY=
FACTORY_OPENAI_BASE_URL=https://api.openai.com/v1

# Logging
FACTORY_LOG_LEVEL=INFO
FACTORY_LOG_FORMAT=json

# Storage
FACTORY_STORAGE_OUTPUT_DIR=./output
FACTORY_STORAGE_RETENTION_DAYS=90
